				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vacunacion_sk as long,",
				"          tiempo_sk as integer,",
				"          establecimiento_sk as integer,",
				"          vacuna_sk as integer,",
				"          paciente_sk as integer,",
				"          registro_id_origen as string,",
				"          cantidad_dosis as integer,",
				"          edad_dias_aplicacion as integer,",
				"          edad_meses_aplicacion as integer,",
				"          temperatura_conservacion as decimal(5,2),",
				"          aplicacion_oportuna as boolean,",
