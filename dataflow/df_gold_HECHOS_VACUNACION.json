				"          nombre_completo,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          grupo_etario,",
				"          municipio_residencia,",
				"          departamento_residencia,",
				"          comunidad_indigena,",
				"          fecha_carga_gold = source4@fecha_carga_gold,",
				"          vacuna_sk,",
				"          es_campana_estacional,",
				"          numero_dosis_total,",
				"          dosis_ml,",
