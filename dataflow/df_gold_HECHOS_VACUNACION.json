				"          es_primera_dosis as boolean,",
				"          numero_dosis as integer,",
				"          lote_vacuna as string,",
				"          via_aplicacion as string,",
				"          fuente_datos as string,",
				"          device_id as string,",
				"          gps_latitud as decimal(10,7),",
