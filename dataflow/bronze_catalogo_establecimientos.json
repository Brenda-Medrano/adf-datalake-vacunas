{
	"name": "bronze_catalogo_establecimientos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_catalogo_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as string,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as string,",
				"          activo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(establecimiento_id = trim(establecimiento_id),",
				"          nombre_establecimiento = trim(nombre_establecimiento) ,",
				"          tipo_establecimiento = trim(tipo_establecimiento),",
				"          zona = trim(zona),",
				"          red_salud = trim(red_salud),",
				"          departamento = lower(trim(departamento)),",
				"          municipio = lower(trim(municipio)),",
				"          sedes = trim(sedes)) ~> derivedColumn1",
				"derivedColumn1 derive(tiene_cadena_frio = iif(lower(trim(tiene_cadena_frio))=='true', true(), false()) ,",
				"          activo = iif(lower(trim(activo))=='true', true(), false()) ,",
				"          nivel_atencion = toInteger(trim(nivel_atencion)) ,",
				"          latitud = toDouble(trim(latitud)) ,",
				"          longitud = toDouble(trim(longitud)) ,",
				"          establecimiento_id = upper(trim(establecimiento_id))) ~> derivedColumn2",
				"derivedColumn2 derive(nombre_establecimiento =  initCap(lower(trim(nombre_establecimiento))) ,",
				"          departamento = initCap(lower(trim(departamento))) ,",
				"          municipio = initCap(lower(trim(municipio))),",
				"          zona = initCap(lower(trim(zona)))) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          departamento,",
				"          municipio,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as integer,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as decimal(10,7),",
				"          longitud as decimal(10,7),",
				"          tiene_cadena_frio as boolean,",
				"          activo as boolean,",
				"          fecha_carga_silver as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          departamento,",
				"          municipio,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     )) ~> sink1"
			]
		}
	}
}