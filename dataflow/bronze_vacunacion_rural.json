{
	"name": "bronze_vacunacion_rural",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_rural_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_rural",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          record_id as string,",
				"          sync_timestamp as string,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as string,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as string,",
				"          vaccination_date as string,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as string,",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as string,",
				"          patient_age_days as string,",
				"          administration_route as string,",
				"          gps_latitude as string,",
				"          gps_longitude as string,",
				"          gps_accuracy_meters as string,",
				"          observations as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(record_id = trim(record_id),",
				"          device_id = trim(upper(device_id)),",
				"          patient_id = trim(upper(patient_id)),",
				"          patient_ci = trim(patient_ci),",
				"          patient_name = trim(initCap(patient_name)),",
				"          patient_last_name_1 = trim(initCap(patient_last_name_1)),",
				"          patient_last_name_2 = trim(initCap(patient_last_name_2)),",
				"          patient_department = trim(initCap(patient_department)),",
				"          patient_municipality = trim(initCap(patient_department)),",
				"          patient_community = trim(initCap(patient_municipality)),",
				"          vaccine_name = trim(initCap(vaccine_name)),",
				"          facility_name = trim(initCap(facility_name)),",
				"          lot_number = trim(upper(lot_number)),",
				"          administration_route = trim(initCap(administration_route)),",
				"          observations = trim(observations),",
				"          facility_code = trim(facility_code)) ~> derivedColumn1",
				"derivedColumn1 derive(dose_number = toInteger(dose_number),",
				"          patient_age_days = toInteger(patient_age_days),",
				"          storage_temp_celsius = toDecimal(storage_temp_celsius, 5, 2),",
				"          gps_latitude = toDecimal(gps_latitude, 10, 7),",
				"          gps_longitude = toDecimal(gps_longitude, 10, 7),",
				"          gps_accuracy_meters = toDecimal(gps_accuracy_meters, 7, 2),",
				"          patient_indigenous = iif(lower(trim(patient_indigenous)) == 'true', true(), false()),",
				"          sync_timestamp = toTimestamp(sync_timestamp, \"yyyy-MM-dd'T'HH:mm:ss\"),",
				"          patient_birth_date = toDate(patient_birth_date, 'yyyy-MM-dd'),",
				"          vaccination_date = toTimestamp(vaccination_date, \"yyyy-MM-dd'T'HH:mm:ss\"),",
				"          patient_id = iif(\r",
				"    isNull(patient_id) || trim(patient_id) == '',\r",
				"    concat('SIN_ID_', toString(toInteger(random(1)*1000))),\r",
				"    trim(patient_id)\r",
				")) ~> derivedColumn2",
				"derivedColumn2 derive(flag_gps_valido = iif(!isNull(gps_latitude) && !isNull(gps_longitude), true(), false()),",
				"          categoria_edad = case(patient_age_days <= 30, 'Recién Nacido', patient_age_days <= 365, 'Menor de 1 año', patient_age_days <= 1825, '1-4 años', patient_age_days <= 6570, '5-17 años', 'Adulto'),",
				"          vaccine_name = iif(     isNull(vaccine_name) || trim(vaccine_name) == '',     'VACUNA_DESCONOCIDA',     upper(trim(vaccine_name)) ),",
				"          storage_temp_celsius = iif(\r",
				"    isNull(storage_temp_celsius),\r",
				"    toDecimal(5.0,5,2),\r",
				"    iif(\r",
				"        storage_temp_celsius < -5,\r",
				"        toDecimal(-5.0,5,2),\r",
				"        iif(\r",
				"            storage_temp_celsius > 25,\r",
				"            toDecimal(25.0,5,2),\r",
				"            storage_temp_celsius\r",
				"        )\r",
				"    )\r",
				"),",
				"          facility_code = iif(\r",
				"    isNull(facility_code) || trim(facility_code) == '',\r",
				"    'FAC_DEFAULT',\r",
				"    upper(trim(facility_code))\r",
				"),",
				"          facility_name = iif(     isNull(facility_name) || trim(facility_name) == '',     'ESTABLECIMIENTO DESCONOCIDO',     upper(trim(facility_name)) ),",
				"          vaccine_code = iif(\r",
				"    isNull(vaccine_code) || trim(vaccine_code) == '',\r",
				"    'SIN_CODIGO',\r",
				"    vaccine_code\r",
				"),",
				"          dose_number = iif(     isNull(dose_number),     0,     toInteger(dose_number) )) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          record_id,",
				"          sync_timestamp,",
				"          device_id,",
				"          patient_id,",
				"          patient_ci,",
				"          patient_name,",
				"          patient_last_name_1,",
				"          patient_last_name_2,",
				"          patient_sex,",
				"          patient_birth_date,",
				"          patient_department,",
				"          patient_municipality,",
				"          patient_community,",
				"          patient_indigenous,",
				"          vaccination_date,",
				"          vaccine_code,",
				"          vaccine_name,",
				"          dose_number,",
				"          facility_code,",
				"          facility_name,",
				"          lot_number,",
				"          storage_temp_celsius,",
				"          patient_age_days,",
				"          administration_route,",
				"          gps_latitude,",
				"          gps_longitude,",
				"          gps_accuracy_meters,",
				"          observations,",
				"          flag_gps_valido,",
				"          categoria_edad",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          record_id as string,",
				"          sync_timestamp as timestamp,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as date,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as boolean,",
				"          vaccination_date as timestamp,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as decimal(3,1),",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as decimal(5,2),",
				"          patient_age_days as integer,",
				"          administration_route as string,",
				"          gps_latitude as decimal(10,7),",
				"          gps_longitude as decimal(10,7),",
				"          gps_accuracy_meters as decimal(7,2),",
				"          observations as string,",
				"          patient_age_months as integer,",
				"          cold_chain_alert as integer,",
				"          load_timestamp as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          record_id,",
				"          sync_timestamp,",
				"          device_id,",
				"          patient_id,",
				"          patient_ci,",
				"          patient_name,",
				"          patient_last_name_1,",
				"          patient_last_name_2,",
				"          patient_sex,",
				"          patient_birth_date,",
				"          patient_department,",
				"          patient_municipality,",
				"          patient_community,",
				"          patient_indigenous,",
				"          vaccination_date,",
				"          vaccine_code,",
				"          vaccine_name,",
				"          dose_number,",
				"          facility_code,",
				"          facility_name,",
				"          lot_number,",
				"          storage_temp_celsius,",
				"          patient_age_days,",
				"          administration_route,",
				"          gps_latitude,",
				"          gps_longitude,",
				"          gps_accuracy_meters,",
				"          observations",
				"     )) ~> sink1"
			]
		}
	}
}