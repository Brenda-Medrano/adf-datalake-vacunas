{
	"name": "bronze_vacunacion_scz",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_scz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_scz",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as string,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as string,",
				"          edad_dias_aplicacion as string,",
				"          aplicacion_oportuna as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(registro_id = trim(registro_id),",
				"          paciente_id = trim(paciente_id),",
				"          ci_paciente = trim(ci_paciente),",
				"          nombre_paciente = trim(initCap(nombre_paciente)),",
				"          apellido_paterno = trim(initCap(apellido_paterno)),",
				"          apellido_materno = trim(initCap(apellido_materno)),",
				"          municipio_residencia = trim(initCap(municipio_residencia)),",
				"          departamento = trim(initCap(departamento)),",
				"          vacuna_nombre = trim(initCap(vacuna_nombre)),",
				"          nombre_establecimiento = trim(initCap(nombre_establecimiento)),",
				"          lote_vacuna = trim(upper(lote_vacuna)),",
				"          via_administracion = trim(initCap(replace(via_administracion, '�', 'á'))),",
				"          comunidad_indigena = iif(lower(trim(comunidad_indigena)) == 'true', true(), false()),",
				"          aplicacion_oportuna = iif(lower(trim(aplicacion_oportuna)) == 'true', true(), false())) ~> derivedColumn1",
				"derivedColumn1 derive(numero_dosis = toInteger(numero_dosis),",
				"          edad_dias_aplicacion = toInteger(edad_dias_aplicacion),",
				"          temperatura_conservacion = toDecimal(temperatura_conservacion, 5, 2),",
				"          fecha_nacimiento = iif(\r",
				"    isNull(fecha_nacimiento) || trim(fecha_nacimiento) == '',\r",
				"    toDate('1900-01-01'),\r",
				"    coalesce(\r",
				"        toDate(fecha_nacimiento, 'MM/dd/yyyy'),\r",
				"        toDate(fecha_nacimiento, 'yyyy-MM-dd')\r",
				"    )\r",
				"),",
				"          fecha_vacunacion = iif(\r",
				"    isNull(fecha_vacunacion) || trim(fecha_vacunacion) == '',\r",
				"    toDate('1900-01-01'),\r",
				"    coalesce(\r",
				"        toDate(fecha_vacunacion, 'MM/dd/yyyy'),\r",
				"        toDate(fecha_vacunacion, 'yyyy-MM-dd')\r",
				"    )\r",
				")) ~> derivedColumn2",
				"derivedColumn2 derive(categoria_edad = case(edad_dias_aplicacion <= 30, 'Recién Nacido', edad_dias_aplicacion <= 365, 'Menor 1 año', edad_dias_aplicacion <= 1825, '1-4 años', edad_dias_aplicacion <= 6570, '5-17 años', 'Adulto'),",
				"          aplicacion_oportuna = iif(aplicacion_oportuna == true(), true(), false())) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          aplicacion_oportuna,",
				"          via_administracion,",
				"          categoria_edad",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 aggregate(groupBy(vacuna_id,",
				"          vacuna_nombre,",
				"          municipio_residencia),",
				"     total_vacunaciones = count(),",
				"          total_oportunas = sum(iif(aplicacion_oportuna, 1, 0)),",
				"          registro_id = first(registro_id),",
				"          paciente_id = first(paciente_id),",
				"          ci_paciente = first(ci_paciente),",
				"          nombre_paciente = first(nombre_paciente),",
				"          apellido_paterno = first(apellido_paterno),",
				"          apellido_materno = first(apellido_materno),",
				"          sexo = first(sexo),",
				"          fecha_nacimiento = first(fecha_nacimiento),",
				"          comunidad_indigena = first(comunidad_indigena),",
				"          numero_dosis = first(numero_dosis),",
				"          establecimiento_id = first(establecimiento_id),",
				"          via_administracion = first(via_administracion),",
				"          aplicacion_oportuna = first(aplicacion_oportuna),",
				"          edad_dias_aplicacion = first(edad_dias_aplicacion),",
				"          temperatura_conservacion = first(temperatura_conservacion),",
				"          lote_vacuna = first(lote_vacuna),",
				"          nombre_establecimiento = first(nombre_establecimiento),",
				"          departamento = first(departamento),",
				"          fecha_vacunacion = first(fecha_vacunacion)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as boolean,",
				"          fecha_vacunacion as date,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as integer,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias_aplicacion as integer,",
				"          via_aplicacion as string,",
				"          aplicacion_oportuna as boolean,",
				"          edad_meses_aplicacion as integer,",
				"          alerta_cadena_frio as integer,",
				"          fecha_carga_silver as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          registro_id,",
				"          paciente_id,",
				"          ci_paciente,",
				"          nombre_paciente,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          sexo,",
				"          fecha_nacimiento,",
				"          municipio_residencia,",
				"          comunidad_indigena,",
				"          fecha_vacunacion,",
				"          vacuna_id,",
				"          vacuna_nombre,",
				"          numero_dosis,",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          departamento,",
				"          lote_vacuna,",
				"          temperatura_conservacion,",
				"          edad_dias_aplicacion,",
				"          via_aplicacion = via_administracion,",
				"          aplicacion_oportuna",
				"     )) ~> sink1"
			]
		}
	}
}