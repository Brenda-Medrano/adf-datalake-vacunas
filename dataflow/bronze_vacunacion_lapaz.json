{
	"name": "bronze_vacunacion_lapaz",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_lapaz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_lapaz",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_registro as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fec_nacimiento as string,",
				"          municipio as string,",
				"          pueblo_indigena as string,",
				"          fec_vacunacion as string,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as string,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          depto as string,",
				"          nro_lote as string,",
				"          temp_conservacion as string,",
				"          edad_dias as string,",
				"          via_aplicacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(id_registro = trim(id_registro),",
				"          cod_paciente = trim(cod_paciente),",
				"          documento_identidad = trim(documento_identidad),",
				"          nombres = trim(initCap(nombres)),",
				"          primer_apellido = trim(initCap(primer_apellido)),",
				"          segundo_apellido = trim(initCap(segundo_apellido)),",
				"          genero = trim(initCap(genero)),",
				"          municipio = trim(initCap(municipio)),",
				"          pueblo_indigena = trim(initCap(pueblo_indigena)),",
				"          cod_vacuna = trim(cod_vacuna),",
				"          desc_vacuna = trim(initCap(desc_vacuna)),",
				"          cod_establecimiento = trim(upper(cod_establecimiento)),",
				"          desc_establecimiento = trim(initCap(desc_establecimiento)),",
				"          depto = lower(trim(depto)),",
				"          nro_lote = trim(nro_lote),",
				"          via_aplicacion = trim(initCap(via_aplicacion))) ~> derivedColumn1",
				"derivedColumn1 derive(nro_dosis = toInteger(nro_dosis),",
				"          edad_dias = toInteger(edad_dias),",
				"          temp_conservacion = toDecimal(temp_conservacion, 4, 2),",
				"          fec_nacimiento = coalesce(\r",
				"    toDate(fec_nacimiento, 'MM/dd/yyyy'),\r",
				"    toDate(fec_nacimiento, 'yyyy-MM-dd')\r",
				"),",
				"          fec_vacunacion = coalesce(\r",
				"    toDate(fec_vacunacion, 'MM/dd/yyyy'),\r",
				"    toDate(fec_vacunacion, 'yyyy-MM-dd')\r",
				"),",
				"          pueblo_indigena = iif(lower(trim(pueblo_indigena)) == 'sí' || lower(trim(pueblo_indigena)) == 'si', true(), false()),",
				"          es_indigena = iif(lower(trim(pueblo_indigena)) == 'sí' || lower(trim(pueblo_indigena)) == 'si', true(), false())) ~> derivedColumn2",
				"derivedColumn2 derive(conservacion_correct = iif(temp_conservacion >= 2 && temp_conservacion <= 8, true(), false()),",
				"          dosis_completa = concat(desc_vacuna, ' - Dosis ', toString(nro_dosis)) ,",
				"          anio_vacunacion = year(fec_vacunacion),",
				"          mes_vacunacion = month(fec_vacunacion),",
				"          categoria_edad = case(edad_dias <= 30, 'Recién Nacido', edad_dias <= 365, 'Menor de 1 año', edad_dias <= 1825, '1-4 años', edad_dias <= 6570, '5-17 años', 'Adulto'),",
				"          edad_meses = round(edad_dias / 30.4375, 2),",
				"          edad_anios = round(edad_dias / 365.25, 2),",
				"          segundo_apellido = iif(isNull(segundo_apellido), '', segundo_apellido),",
				"          nro_lote = iif(isNull(nro_lote) || trim(nro_lote)=='', 'Sin Lote', nro_lote)) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          id_registro,",
				"          cod_paciente,",
				"          documento_identidad,",
				"          nombres,",
				"          primer_apellido,",
				"          segundo_apellido,",
				"          genero,",
				"          fec_nacimiento,",
				"          municipio,",
				"          pueblo_indigena,",
				"          fec_vacunacion,",
				"          cod_vacuna,",
				"          desc_vacuna,",
				"          nro_dosis,",
				"          cod_establecimiento,",
				"          desc_establecimiento,",
				"          depto,",
				"          nro_lote,",
				"          temp_conservacion,",
				"          edad_dias,",
				"          via_aplicacion,",
				"          es_indigena,",
				"          conservacion_correct,",
				"          dosis_completa,",
				"          anio_vacunacion,",
				"          mes_vacunacion,",
				"          categoria_edad,",
				"          edad_meses,",
				"          edad_anios",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 aggregate(groupBy(cod_vacuna,",
				"          categoria_edad,",
				"          anio_vacunacion,",
				"          desc_vacuna,",
				"          cod_establecimiento),",
				"     total_vacunaciones = count(),",
				"          total_pacientes_unicos = countDistinct(cod_paciente),",
				"          id_registro = first(id_registro),",
				"          cod_paciente = first(cod_paciente),",
				"          documento_identidad = first(documento_identidad),",
				"          nombres = first(nombres),",
				"          primer_apellido = first(primer_apellido),",
				"          segundo_apellido = first(segundo_apellido),",
				"          genero = first(genero),",
				"          fec_nacimiento = first(fec_nacimiento),",
				"          municipio = first(municipio),",
				"          pueblo_indigena = first(pueblo_indigena),",
				"          fec_vacunacion = first(fec_vacunacion),",
				"          nro_dosis = first(nro_dosis),",
				"          desc_establecimiento = first(desc_establecimiento),",
				"          depto = first(depto),",
				"          nro_lote = first(nro_lote),",
				"          temp_conservacion = first(temp_conservacion),",
				"          edad_dias = first(edad_dias),",
				"          via_aplicacion = first(via_aplicacion)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as boolean,",
				"          fecha_vacunacion as date,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as integer,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias_aplicacion as integer,",
				"          via_aplicacion as string,",
				"          edad_meses_aplicacion as integer,",
				"          alerta_cadena_frio as integer,",
				"          fecha_carga_silver as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          registro_id = id_registro,",
				"          paciente_id = cod_paciente,",
				"          ci_paciente = documento_identidad,",
				"          nombre_paciente = nombres,",
				"          apellido_paterno = primer_apellido,",
				"          apellido_materno = segundo_apellido,",
				"          sexo = genero,",
				"          fecha_nacimiento = fec_nacimiento,",
				"          municipio_residencia = municipio,",
				"          comunidad_indigena = pueblo_indigena,",
				"          fecha_vacunacion = fec_vacunacion,",
				"          vacuna_id = cod_vacuna,",
				"          vacuna_nombre = desc_vacuna,",
				"          numero_dosis = nro_dosis,",
				"          establecimiento_id = cod_establecimiento,",
				"          nombre_establecimiento = desc_establecimiento,",
				"          departamento = depto,",
				"          lote_vacuna = nro_lote,",
				"          temperatura_conservacion = temp_conservacion,",
				"          edad_dias_aplicacion = edad_dias,",
				"          via_aplicacion",
				"     )) ~> sink1"
			]
		}
	}
}